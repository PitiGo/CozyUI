                            </p>
                            <p className="text-xs text-slate-500">
                              {cachedInfo ? formatBytes(cachedInfo.size) : model?.size || 'Unknown size'}
                              {cachedInfo?.fileCount && ` • ${cachedInfo.fileCount} archivos`}
                            </p>
