      originalAspect: width / height
    });
  }, [id, keepAspectRatio, width, height, updateNodeData]);

  return (
    <BaseNode 
      title="Resize" 
      icon={<Maximize size={16} />}
      color="sky"
      selected={selected}
      minWidth={180}
    >
      {/* Input Handle */}
