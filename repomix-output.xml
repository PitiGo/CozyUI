];

const colorClasses = {
  indigo: 'bg-indigo-500/20 border-indigo-500/30 text-indigo-400 hover:bg-indigo-500/30',
  violet: 'bg-violet-500/20 border-violet-500/30 text-violet-400 hover:bg-violet-500/30',
